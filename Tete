# Класс для представления игрока
class Player:
    def __init__(self):
        self.hp = 10
        self.inventory = []
    
    # Добавить предмет в инвентарь
    def add_item(self, item):
        self.inventory.append(item)
        print(f"Вы получили: {item}")
    
    # Изменить HP игрока
    def change_hp(self, amount):
        self.hp += amount
        if amount > 0:
            print(f"HP +{amount}")
        else:
            print(f"HP {amount}")
    
    # Проверить, жив ли игрок
    def is_alive(self):
        return self.hp > 0
    
    # Получить текущий статус игрока
    def get_status(self):
        return f"HP: {self.hp} | Инвентарь: {', '.join(self.inventory) if self.inventory else 'пусто'}"


